# ============================================================
# GameTrack Environment Variables
# ============================================================
# Copy this file to .env and fill in the values.
# Lines starting with # are comments and are ignored.

# ------ Site Configuration ------
# Base URL of your deployed application (localhost for development).
# Required for Next.js Server Actions and API routes.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ------ Twitch / IGDB API Credentials ------
# Required to fetch game data, platforms, and artwork.
# 1. Go to https://dev.twitch.tv/console
# 2. Register your application
# 3. Generate a Client ID and Client Secret
IGDB_CLIENT_ID=your_twitch_client_id_here
IGDB_CLIENT_SECRET=your_twitch_client_secret_here

# ------ Database ------
# Controls which database engine is used at runtime.
# No setup scripts needed — just set this value and start the app.
#
# SQLite (default — no external database required):
#   Leave empty or set to any non-postgres value.
#   Data is stored locally in ./data/gametrack.db
#
# PostgreSQL (production):
#   Set to a full Postgres connection string:
#   DATABASE_URL="postgresql://user:password@localhost:5432/gametrack"
#
DATABASE_URL=

# ------ Authentication ------
# Secret key used to sign JWT session tokens.
# REQUIRED in production — use a strong random string (32+ characters).
# Generate one with: openssl rand -base64 32
#
# In development, a fallback default is used if this is empty.
JWT_SECRET=change-me-to-a-random-secret-in-production
